{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "feature": "user-job-notice",
  "title": "사용자 채용 공고 API 명세",
  "description": "채용 공고 목록 페이지와 상세 페이지가 공통으로 사용하는 프론트엔드 API 계약이다.",
  "version": "0.1.0",
  "locale": "ko-KR",
  "owners": [
    "user-frontend",
    "user-backend"
  ],
  "basePath": "/api/user/job-notices",
  "sharedBy": [
    "list",
    "detail"
  ],
  "auth": {
    "publicRead": true,
    "bookmarkRequiresLogin": true,
    "loginRedirectPath": "/auth/login"
  },
  "responseConvention": {
    "wrapper": "ApiResponse<T>",
    "fields": {
      "success": "boolean",
      "statusCode": "number",
      "message": "string",
      "data": "T | null"
    },
    "successExample": {
      "success": true,
      "statusCode": 200,
      "message": "요청이 성공했습니다.",
      "data": {}
    },
    "failureExample": {
      "success": false,
      "statusCode": 400,
      "message": "지원하지 않는 필터 값입니다.",
      "data": null
    },
    "notes": [
      "Controller는 Map 또는 Entity를 직접 반환하지 않는다.",
      "예상 가능한 실패는 ErrorCode와 공통 예외 흐름을 통해 ApiResponse.fail(statusCode, message) 형태로 반환한다.",
      "프론트엔드는 success가 false이거나 HTTP 상태가 실패인 경우 message를 사용자 안내 문구로 사용한다."
    ]
  },
  "enums": {
    "jobType": [
      "전체",
      "백엔드",
      "프론트엔드",
      "데이터",
      "DevOps"
    ],
    "experience": [
      "전체",
      "신입",
      "1~3년",
      "3~5년",
      "5년 이상",
      "경력무관"
    ],
    "employmentType": [
      "전체",
      "정규직",
      "인턴",
      "계약직"
    ],
    "location": [
      "전체",
      "서울",
      "경기",
      "원격"
    ],
    "companySize": [
      "전체",
      "스타트업",
      "중견",
      "대기업"
    ],
    "period": [
      "today",
      "7d",
      "30d",
      "all"
    ],
    "sort": [
      "recommend",
      "latest",
      "views"
    ]
  },
  "entities": {
    "JobNoticeSummary": {
      "description": "목록 카드에 표시되는 최소 공고 정보",
      "required": [
        "id",
        "company",
        "title",
        "jobType",
        "experience",
        "employmentType",
        "location",
        "companySize",
        "deadline",
        "postedAt",
        "tags",
        "source",
        "recommended",
        "recommendScore",
        "views",
        "bookmarked"
      ],
      "properties": {
        "id": {
          "type": "number",
          "description": "공고 고유 ID"
        },
        "company": {
          "type": "string",
          "description": "회사명"
        },
        "title": {
          "type": "string",
          "description": "공고 제목"
        },
        "jobType": {
          "type": "string",
          "description": "직무 분류"
        },
        "experience": {
          "type": "string",
          "description": "경력 조건"
        },
        "employmentType": {
          "type": "string",
          "description": "고용 형태"
        },
        "location": {
          "type": "string",
          "description": "근무 지역"
        },
        "companySize": {
          "type": "string",
          "description": "기업 규모"
        },
        "salary": {
          "type": "string",
          "description": "급여 정보. 공개되지 않은 경우 협의로 내려온다."
        },
        "deadline": {
          "type": "string",
          "description": "마감 정보. 예: 상시, D-7, 2026-06-30"
        },
        "postedAt": {
          "type": "string",
          "format": "date",
          "description": "게시일"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "카드에 노출할 핵심 태그"
        },
        "source": {
          "type": "string",
          "description": "공고 출처. 예: 그룹바이, 직접등록, 원티드"
        },
        "recommended": {
          "type": "boolean",
          "description": "추천 배지 노출 여부"
        },
        "recommendScore": {
          "type": "number",
          "description": "추천순 정렬에 사용하는 점수"
        },
        "views": {
          "type": "number",
          "description": "조회수"
        },
        "bookmarked": {
          "type": "boolean",
          "description": "현재 로그인 사용자의 스크랩 여부"
        },
        "originalUrl": {
          "type": "string",
          "format": "uri",
          "description": "원본 공고 URL"
        },
        "stacks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "기술 스택"
        }
      }
    },
    "JobNoticeDetail": {
      "description": "상세 드로어에서 표시하는 공고 상세 정보",
      "allOf": [
        "JobNoticeSummary"
      ],
      "properties": {
        "industry": {
          "type": "string",
          "description": "업종"
        },
        "responsibilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "담당 업무"
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "필수 자격 요건"
        },
        "preferredQualifications": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "우대 사항"
        },
        "process": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "전형 절차"
        },
        "workConditions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "근무 조건"
        },
        "companyDescription": {
          "type": "string",
          "description": "기업 소개"
        }
      }
    }
  },
  "endpoints": [
    {
      "id": "getJobNoticeList",
      "method": "GET",
      "path": "/api/user/job-notices",
      "summary": "채용 공고 목록 조회",
      "auth": "optional",
      "query": {
        "keyword": {
          "type": "string",
          "required": false,
          "description": "회사명, 공고명, 직무, 기술 스택, 출처 통합 검색어"
        },
        "jobType": {
          "type": "string",
          "required": false,
          "description": "직무 필터. 전체 선택 시 생략"
        },
        "experience": {
          "type": "string",
          "required": false,
          "description": "경력 필터. 범위 필터는 서버가 교집합 기준으로 처리"
        },
        "employmentType": {
          "type": "string",
          "required": false,
          "description": "채용 유형 필터"
        },
        "location": {
          "type": "string",
          "required": false,
          "description": "지역 필터"
        },
        "companySize": {
          "type": "string",
          "required": false,
          "description": "기업 규모 필터"
        },
        "period": {
          "type": "string",
          "enumRef": "period",
          "default": "all",
          "description": "게시일 기준 기간 필터"
        },
        "sort": {
          "type": "string",
          "enumRef": "sort",
          "default": "recommend",
          "description": "추천순, 최신순, 조회순 정렬"
        },
        "page": {
          "type": "number",
          "default": 1,
          "minimum": 1
        },
        "size": {
          "type": "number",
          "default": 18,
          "minimum": 1,
          "maximum": 60
        }
      },
      "response": {
        "wrapper": "ApiResponse<JobNoticeListResponse>",
        "data": {
          "items": "JobNoticeSummary[]",
          "page": "number",
          "size": "number",
          "totalItems": "number",
          "totalPages": "number",
          "stats": {
            "totalOpenCount": "number",
            "todayNewCount": "number",
            "todayNewDelta": "number",
            "todayNewRate": "number"
          },
          "filterOptions": {
            "jobType": "string[]",
            "experience": "string[]",
            "employmentType": "string[]",
            "location": "string[]",
            "companySize": "string[]"
          }
        }
      },
      "emptyState": {
        "status": 200,
        "items": [],
        "message": "조건에 맞는 공고가 없습니다."
      },
      "errors": [
        {
          "code": "INVALID_JOB_NOTICE_FILTER",
          "status": 400,
          "message": "지원하지 않는 필터 값입니다."
        },
        {
          "code": "JOB_NOTICE_LIST_UNAVAILABLE",
          "status": 503,
          "message": "채용 공고 목록을 불러올 수 없습니다."
        }
      ]
    },
    {
      "id": "getJobNoticeDetail",
      "method": "GET",
      "path": "/api/user/job-notices/{jobNoticeId}",
      "summary": "채용 공고 상세 조회",
      "auth": "optional",
      "pathParams": {
        "jobNoticeId": {
          "type": "number",
          "required": true,
          "description": "상세 조회할 공고 ID"
        }
      },
      "response": {
        "wrapper": "ApiResponse<JobNoticeDetail>",
        "data": "JobNoticeDetail"
      },
      "errors": [
        {
          "code": "JOB_NOTICE_NOT_FOUND",
          "status": 404,
          "message": "공고 정보를 찾을 수 없습니다."
        },
        {
          "code": "JOB_NOTICE_CLOSED",
          "status": 410,
          "message": "마감되었거나 비공개 처리된 공고입니다."
        }
      ]
    },
    {
      "id": "toggleJobNoticeBookmark",
      "method": "PATCH",
      "path": "/api/user/job-notices/{jobNoticeId}/bookmark",
      "summary": "채용 공고 스크랩 토글",
      "auth": "required",
      "pathParams": {
        "jobNoticeId": {
          "type": "number",
          "required": true
        }
      },
      "request": {
        "contentType": "application/json",
        "body": {
          "bookmarked": {
            "type": "boolean",
            "required": true,
            "description": "true면 스크랩 저장, false면 스크랩 해제"
          }
        }
      },
      "response": {
        "wrapper": "ApiResponse<JobNoticeBookmarkResponse>",
        "data": {
          "jobNoticeId": "number",
          "bookmarked": "boolean",
          "scrapCount": "number"
        }
      },
      "errors": [
        {
          "code": "UNAUTHORIZED",
          "status": 401,
          "message": "로그인이 필요한 기능입니다."
        },
        {
          "code": "JOB_NOTICE_NOT_FOUND",
          "status": 404,
          "message": "공고 정보를 찾을 수 없습니다."
        }
      ]
    }
  ],
  "frontendMapping": {
    "listPage": "frontend/src/user/pages/jobNotice/JobNoticeListPage.tsx",
    "detailDrawer": "frontend/src/user/pages/jobNotice/JobNoticeDetail.tsx",
    "sharedType": "frontend/src/user/pages/jobNotice/JobNoticeTypes.ts",
    "apiModule": "frontend/src/user/api/jobApi.js 또는 frontend/src/user/api/jobNoticeApi.ts",
    "apiClient": "frontend/src/utils/apiClient.js"
  },
  "notes": [
    "목록과 상세는 동일한 id와 bookmarked 값을 공유해야 한다.",
    "목록 조회는 공개 API이지만 로그인 상태에서는 사용자별 스크랩 여부를 함께 내려준다.",
    "원본 공고 이동은 originalUrl이 있을 때 해당 URL을 사용하고, 없을 때는 검색 URL fallback을 사용한다."
  ]
}
