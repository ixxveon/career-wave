{
  "openapi": "3.0.3",
  "info": {
    "title": "Career Wave User - Member API",
    "version": "0.0.1"
  },
  "paths": {
    "/api/v1/auth/signup": {
      "post": {
        "summary": "회원가입",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "nickname": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "회원가입 성공" }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "summary": "로그인",
        "responses": {
          "200": { "description": "로그인 성공, Access Token 반환" }
        }
      }
    }
  }
}
