{
  "feature": "company",
  "version": "1.0.0",
  "endpoints": [
    {
      "method": "GET",
      "path": "/api/admin/companies",
      "description": "기업 목록 조회",
      "auth": "ADMIN+",
      "query": {
        "status": "PENDING | APPROVED | REJECTED | SUSPENDED (optional)",
        "page": "number (default: 0)",
        "size": "number (default: 20)"
      },
      "response": {
        "content": "[CompanyListResponse]",
        "totalElements": "number",
        "totalPages": "number"
      }
    },
    {
      "method": "GET",
      "path": "/api/admin/companies/{id}",
      "description": "기업 상세 조회",
      "auth": "ADMIN+",
      "response": {
        "id": "number",
        "name": "string",
        "businessNumber": "string",
        "description": "string",
        "logoUrl": "string",
        "status": "string",
        "createdAt": "datetime"
      }
    },
    {
      "method": "PATCH",
      "path": "/api/admin/companies/{id}/approve",
      "description": "기업 승인",
      "auth": "ADMIN+",
      "response": { "id": "number", "status": "APPROVED" }
    },
    {
      "method": "PATCH",
      "path": "/api/admin/companies/{id}/reject",
      "description": "기업 반려",
      "auth": "ADMIN+",
      "response": { "id": "number", "status": "REJECTED" }
    }
  ]
}
