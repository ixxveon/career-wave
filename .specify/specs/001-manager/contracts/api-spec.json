{
  "feature": "manager-auth",
  "version": "1.0.0",
  "endpoints": [
    {
      "method": "POST",
      "path": "/api/admin/auth/login",
      "description": "관리자 로그인",
      "request": {
        "email": "string",
        "password": "string"
      },
      "response": {
        "accessToken": "string",
        "refreshToken": "string",
        "tokenType": "Bearer"
      }
    },
    {
      "method": "POST",
      "path": "/api/admin/auth/refresh",
      "description": "토큰 갱신",
      "request": {
        "refreshToken": "string"
      },
      "response": {
        "accessToken": "string"
      }
    },
    {
      "method": "POST",
      "path": "/api/admin/managers",
      "description": "관리자 계정 생성 (SUPER_ADMIN 전용)",
      "auth": "SUPER_ADMIN",
      "request": {
        "email": "string",
        "password": "string",
        "name": "string",
        "role": "ADMIN | SUPER_ADMIN"
      },
      "response": {
        "id": "number",
        "email": "string",
        "name": "string",
        "role": "string"
      }
    }
  ]
}
